    {
      "parameters": {
        "mode": "runOnceForEachItem",
        "jsCode": "const prev = $('Extract CEO Name & LinkedIn').item.json;\nconst person = $json.person || {};\nconst matched = $json.matched_person || {};\nconst p = Object.keys(person).length ? person : matched;\nconst workEmail = p.email || p.work_email || '';\nconst personalEmail = (p.personal_emails && p.personal_emails[0]) || '';\nconst phones = p.phone_numbers || [];\nconst mobile = phones.find(x => /mobile|personal/i.test(x.type || '')) || phones[0] || {};\nconst phone = mobile.sanitized_number || mobile.raw_number || p.sanitized_phone || p.mobile_phone || p.phone || '';\nreturn { json: { ...prev, ceoWorkEmail: workEmail, ceoPersonalEmail: personalEmail, ceoPhone: phone } };"
      },
