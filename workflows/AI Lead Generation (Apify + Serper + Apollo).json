    {
      "parameters": {
        "mode": "runOnceForEachItem",
        "jsCode": "const prev = $('Extract Company Email & Phone').item.json;\nconst results = ($json.organic_results || $json.organic || []);\nlet ceoName = '';\nlet ceoLinkedIn = '';\nfor (const r of results) {\n  const link = (r.link || '').split('?')[0];\n  if (/linkedin\\.com\\/in\\//i.test(link)) {\n    ceoLinkedIn = link;\n    const raw = (r.title || '').split(' | ')[0];\n    const parts = raw.split(' - ');\n    ceoName = (parts[0] || '').replace(/\\s+/g, ' ').trim();\n    break;\n  }\n}\nreturn { json: { ...prev, ceoName, ceoLinkedIn } };"
      },
